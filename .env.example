# ================================================================
#  .env.example  —  Copia in .env e compila i valori reali
#  NON committare mai il file .env nel repository Git!
# ================================================================

# ── Server ───────────────────────────────────────────────────────
NODE_ENV=development        # development | production
PORT=3000

# ── Database ─────────────────────────────────────────────────────
# Opzione 1 — Railway / Neon / Supabase forniscono DATABASE_URL automaticamente
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Opzione 2 — Variabili separate (sviluppo locale)
DB_HOST=localhost
DB_PORT=5432
DB_USER=volley_app
DB_PASSWORD=Magonero1!
DB_NAME=volleyball
DB_SSL=false                # true in produzione con Railway/Neon

# ── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=cambia_questo_con_una_stringa_lunga_e_casuale_min_32_chars
JWT_EXPIRY=8h

# ── CORS ─────────────────────────────────────────────────────────
# In produzione: dominio del tuo frontend (senza trailing slash)
ALLOWED_ORIGINS=http://localhost:5173

# ── Registrazione ────────────────────────────────────────────────
ALLOW_PUBLIC_REGISTER=false
REGISTER_INVITE_CODE=VOLLEY2026
